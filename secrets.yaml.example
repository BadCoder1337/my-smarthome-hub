# Скопируй в secrets.yaml (он в .gitignore) и подставь свои значения.
# В Home Assistant ESPHome Dashboard эти ключи лежат в /config/esphome/secrets.yaml

wifi_ssid: "MyWiFi"
wifi_password: "wifi-password"
fallback_ap_password: "fallback-ap-password"

esphome_rf_hub__encryption_key: "base64-encryption-key-32-bytes"
esphome_rf_hub__ota_password: "ota-password"

# Разрешённые пульты — 20-битные ID (старшие биты декодированного PT2262-кода).
# Добавить новый пульт = дописать его ID в этот список.
rf_remotes: [0x12345, 0x6789A]
